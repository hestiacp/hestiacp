#!/bin/bash
# info: delete database server
# options: TYPE HOST [PORT]
#
# example: v-delete-database-host pgsql localhost
#
# This function for deleting the database host from hestia configuration. It will
# be deleted if there are no databases created on it only.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
type=$1
host=$2
port=$3

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source /etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# shellcheck source=/usr/local/hestia/func/db.sh
source $HESTIA/func/db.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'TYPE HOST [PORT]'
is_format_valid 'type' 'host'
if [ -n "$port" ]; then
	is_format_valid 'port'
fi
is_system_enabled "$DB_SYSTEM" 'DB_SYSTEM'
is_type_valid "$DB_SYSTEM" "$type"
is_dbhost_free

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Deleting server
sed -i "${DBHOST_LINE}d" "$HESTIA/conf/$type.conf"
if [ -z "$(grep "HOST=" "$HESTIA/conf/$type.conf" 2> /dev/null)" ]; then
	db=$(echo "$DB_SYSTEM" \
		| sed "s/,/\n/g" \
		| grep -vx "$type" \
		| sed "/^$/d" \
		| sed ':a;N;$!ba;s/\n/,/g')
	if [ -z "$db" ]; then
		db="no"
	fi
	sed -i "s/DB_SYSTEM=.*/DB_SYSTEM='$db'/g" "$HESTIA/conf/hestia.conf"
fi
# Delete RRD database
rm -fr $HESTIA'/web/rrd/db/'$type'_'$host'.rrd'
rm -fr $HESTIA'/web/rrd/db/'*-$type'_'$host'.*'
endpoint_id=$(database_get_endpoint_id "$HOST" "$PORT")
rm -fr $HESTIA'/web/rrd/db/'$type'_'$endpoint_id'.rrd'
rm -fr $HESTIA'/web/rrd/db/'*-$type'_'$endpoint_id'.*'

if [ "$type" = "mysql" ]; then
	$BIN/v-update-sys-pma-hosts
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/v-log-action "system" "Info" "Database" "Removed remote database host (Host: $HOST, Port: $PORT, Type: $type)."
log_event "$OK" "$ARGUMENTS"

exit
