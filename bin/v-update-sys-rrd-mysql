#!/bin/bash
# info: update MySQL rrd
# options: PERIOD
#
# example: v-update-sys-rrd-mysql
#
# This function is for updating mysql rrd database and graphic.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
period=${1-daily}

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source /etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# shellcheck source=/usr/local/hestia/func/db.sh
source $HESTIA/func/db.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Switching on time period
case $period in
	daily)
		start='-1d'
		end='now'
		grid='MINUTE:30:HOUR:1:HOUR:4:0:%H:%M'
		;;
	weekly)
		start='-7d'
		end='now'
		grid='HOUR:8:DAY:1:DAY:1:0:%a %d'
		;;
	monthly)
		start='-1m'
		end='now'
		grid='WEEK:1:WEEK:1:WEEK:1:0:%b %d'
		;;
	yearly)
		start='-1y'
		end='now'
		grid='MONTH:1:YEAR:1:MONTH:2:2419200:%b'
		;;
	*) exit "$E_RRD" ;;
esac

# Checking directory
if [ ! -d "$RRD/db" ]; then
	mkdir $RRD/db
fi

# Parsing db hosts
conf="$HESTIA/conf/mysql.conf"
hosts=$(grep HOST "$conf")
check_row=$(echo "$hosts" | grep -c HOST)
if [ 0 -eq "$check_row" ]; then
	exit
fi

OLD_IFS="$IFS"
IFS=$'\n'
for host_str in $hosts; do
	unset HOST PORT
	parse_object_kv_list "$host_str"
	if [ -z "$PORT" ]; then PORT=$(database_get_default_port "mysql"); fi
	host="$HOST"
	port="$PORT"
	endpoint=$(database_get_endpoint "$host" "$port")
	endpoint_id=$(database_get_endpoint_id "$host" "$port")
	skip_host="no"
	for exclude in $(echo ${RRD_MYSQL_EXCLUDE//,/ }); do
		if [ "$exclude" = "$host" ] || [ "$exclude" = "$endpoint" ]; then
			skip_host="yes"
		fi
	done
	if [ "$skip_host" = "yes" ]; then
		continue
	fi

	# Checking database
	if [ ! -e "$RRD/db/mysql_$endpoint_id.rrd" ]; then
		# Adding database
		rrdtool create $RRD/db/mysql_$endpoint_id.rrd --step $RRD_STEP \
			DS:A:COUNTER:600:U:U \
			DS:S:COUNTER:600:U:U \
			RRA:AVERAGE:0.5:1:600 \
			RRA:AVERAGE:0.5:6:700 \
			RRA:AVERAGE:0.5:24:775 \
			RRA:AVERAGE:0.5:288:797 \
			RRA:MAX:0.5:1:600 \
			RRA:MAX:0.5:6:700 \
			RRA:MAX:0.5:24:775 \
			RRA:MAX:0.5:288:797
	fi

	if [ "$period" = 'daily' ]; then
		mysql_connect "$host" "$port"
		query='SHOW GLOBAL STATUS'
		status=$(mysql_query "$query" 2> /dev/null)
		if [ $? -ne 0 ]; then
			active=0
			slow=0
		else
			active=$(echo "$status" | grep 'Queries' | cut -f 2)
			slow=$(echo "$status" | grep 'Slow_queries' | cut -f 2)
		fi

		# Updating rrd
		rrdtool update $RRD/db/mysql_$endpoint_id.rrd N:$active:$slow
	fi

	# Updating daily graph
	rrdtool graph $RRD/db/$period-mysql_$endpoint_id.png \
		--imgformat PNG \
		--height="150" \
		--width="670" \
		--start "$start" \
		--end "$end" \
		--vertical-label "Queries" \
		--x-grid "$grid" \
		-c "BACK#ffffff" \
		-c "SHADEA#ffffff" \
		-c "SHADEB#ffffff" \
		-c "FONT#555555" \
		-c "CANVAS#302c2d" \
		-c "GRID#666666" \
		-c "MGRID#AAAAAA" \
		-c "FRAME#302c2d" \
		-c "ARROW#FFFFFF" \
		DEF:a=$RRD/db/mysql_$endpoint_id.rrd:A:AVERAGE \
		DEF:s=$RRD/db/mysql_$endpoint_id.rrd:S:AVERAGE \
		COMMENT:'\r' \
		LINE1:a#fefda0:"Queries" \
		GPRINT:a:'LAST: Current\:''%8.0lf' \
		GPRINT:a:'MIN: Min\:''%8.0lf' \
		GPRINT:a:'MAX: Max\:''%8.0lf\j' \
		AREA:s#f57900:"Slow   " \
		GPRINT:s:'LAST:Current\:''%8.0lf' \
		GPRINT:s:'MIN:Min\:''%8.0lf' \
		GPRINT:s:'MAX:Max\:''%8.0lf\j' &> /dev/null
	result=$?

	if [ "$result" -ne 0 ]; then
		exit "$E_RRD"
	fi

done
IFS="$OLD_IFS"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
