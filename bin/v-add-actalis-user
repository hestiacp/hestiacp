#!/bin/bash
# info: register actalis user account
# options: USER
#
# example: v-add-actalis-user bob
#
# This function creates and register Actalis account

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source /etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

account_registered='no'

ACTALIS_API='https://acme-api.actalis.com/acme'

# encode base64
encode_base64() {
	cat | base64 | tr '+/' '-_' | tr -d '\r\n='
}

# Actalis curl function
query_actalis() {
	protected='{"nonce": "'$3'",'
	protected=''$protected' "url": "'$1'",'
	protected=''$protected' "alg": "RS256", "jwk": '$jwk'}'
	content="Content-Type: application/jose+json"

	payload_=$(echo -n "$2" | encode_base64)
	protected_=$(echo -n "$protected" | encode_base64)
	signature_=$(printf "%s" "$protected_.$payload_" \
		| openssl dgst -sha256 -binary -sign $USER_DATA/ssl/user.key \
		| encode_base64)

	post_data='{"protected":"'"$protected_"'",'
	post_data=$post_data'"payload":"'"$payload_"'",'
	post_data=$post_data'"signature":"'"$signature_"'"}'

	curl --user-agent "HestiaCP" -s -i -d "$post_data" "$1" -H "$content"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"
if [ -e "$USER_DATA/ssl/actalis.conf" ]; then
	source "$USER_DATA/ssl/actalis.conf"
fi
if [ -n "$KID" ]; then
	account_registered='yes'
	kid="$KID"
fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Defining user email
if [[ -z "$EMAIL" ]]; then
	EMAIL=$(get_user_value '$CONTACT')
fi

# Defining user agreement
agreement=''

# Generating user key
KEY="$USER_DATA/ssl/user.key"
if [ ! -e "$KEY" ]; then
	openssl genrsa -out "$KEY" 4096 > /dev/null 2>&1
	chmod 600 $KEY
fi

# Defining key exponent
if [ -z "$EXPONENT" ]; then
	EXPONENT=$(openssl pkey -inform pem -in "$KEY" -noout -text_pub \
		| grep Exponent: | cut -f 2 -d '(' | cut -f 1 -d ')' | sed -e 's/x//' \
		| xxd -r -p | encode_base64)
fi

# Defining key modulus
if [ -z "$MODULUS" ]; then
	MODULUS=$(openssl rsa -in "$KEY" -modulus -noout \
		| sed -e 's/^Modulus=//' | xxd -r -p | encode_base64)
fi

# Defining JWK
jwk='{"e":"'$EXPONENT'","kty":"RSA","n":"'"$MODULUS"'"}'

# Defining key thumbnail
if [ -z "$THUMB" ]; then
	THUMB="$(echo -n "$jwk" | openssl dgst -sha256 -binary | encode_base64)"
fi

if [ "$account_registered" = 'no' ]; then
	# Requesting ACME nonce
	nonce=$(curl -s -I "$ACTALIS_API/newnonce" | grep -i nonce | cut -f2 -d\  | tr -d '\r\n')

	# Creating ACME account
	url="$ACTALIS_API/newaccount"
	eab_protected=$(echo -n '{"alg":"HS256","kid":"'$EAB_KID'","url":"'$url'"}' | encode_base64)
	eab_payload=$(echo -n "$jwk" | encode_base64)
	eab_sig=$(printf "%s" "$eab_protected.$eab_payload" \
		| openssl dgst -sha256 -binary -mac HMAC \
			-macopt "key:$(echo -n $EAB_HMAC | base64 -d)" \
		| encode_base64)

	eab='{"protected":"'$eab_protected'","payload":"'$eab_payload'","signature":"'$eab_sig'"}'
	payload='{"termsOfServiceAgreed":true,"externalAccountBinding":'$eab'}'
	answer=$(query_actalis "$url" "$payload" "$nonce")
	kid=$(echo "$answer" | grep -i location: | cut -f2 -d ' ' | tr -d '\r')

	# Checking answer status
	status=$(echo "$answer" | grep HTTP/ | tail -n1 | cut -f2 -d ' ')
	if [[ "${status:0:2}" -ne "20" ]]; then
		check_result "$E_CONNECT" "Actalis acc registration failed $status"
	fi
fi

#----------------------------------------------------------#
#                        Hestia                            #
#----------------------------------------------------------#

# Adding actalis.conf
if [ ! -e "$USER_DATA/ssl/actalis.conf" ]; then
	echo "EXPONENT='$EXPONENT'" > $USER_DATA/ssl/actalis.conf
	echo "MODULUS='$MODULUS'" >> $USER_DATA/ssl/actalis.conf
	echo "THUMB='$THUMB'" >> $USER_DATA/ssl/actalis.conf
	echo "EMAIL='$EMAIL'" >> $USER_DATA/ssl/actalis.conf
	echo "KID='$kid'" >> $USER_DATA/ssl/actalis.conf
	echo "EAB_KID='$EAB_KID'" >> $USER_DATA/ssl/actalis.conf
	echo "EAB_HMAC='$EAB_HMAC'" >> $USER_DATA/ssl/actalis.conf
	echo "EAB_DATE='$(date +%Y-%m-%d)'" >> $USER_DATA/ssl/actalis.conf
	chmod 660 $USER_DATA/ssl/actalis.conf
else
	sed -i '/^EMAIL=/d' "$USER_DATA/ssl/actalis.conf"
	sed -i '/^EXPONENT=/d' "$USER_DATA/ssl/actalis.conf"
	sed -i '/^MODULUS=/d' "$USER_DATA/ssl/actalis.conf"
	sed -i '/^THUMB=/d' "$USER_DATA/ssl/actalis.conf"
	sed -i '/^KID=/d' "$USER_DATA/ssl/actalis.conf"

	echo "EMAIL='$EMAIL'" >> "$USER_DATA/ssl/actalis.conf"
	echo "EXPONENT='$EXPONENT'" >> "$USER_DATA/ssl/actalis.conf"
	echo "MODULUS='$MODULUS'" >> "$USER_DATA/ssl/actalis.conf"
	echo "THUMB='$THUMB'" >> "$USER_DATA/ssl/actalis.conf"
	echo "KID='$kid'" >> "$USER_DATA/ssl/actalis.conf"
fi

# Logging
log_event "$OK" "$ARGUMENTS"

exit
