#!/bin/bash
# info: scan and register Laravel app
# options: USER DOMAIN [PATH] [FORMAT]
#
# example: v-scan-laravel-app admin example.com /home/admin/web/example.com/public_html json
#
# This function scans a web domain path for Laravel files and registers it.

user=$1
domain=$2
app_root=${3-}
format=${4-shell}

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source /etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# shellcheck source=/usr/local/hestia/func/laravel.sh
source $HESTIA/func/laravel.sh
source_conf "$HESTIA/conf/hestia.conf"

check_args '2' "$#" 'USER DOMAIN [PATH] [FORMAT]'
is_format_valid 'user' 'domain' 'format'
is_object_valid 'user' 'USER' "$user"
is_object_unsuspended 'user' 'USER' "$user"
is_object_valid 'web' 'DOMAIN' "$domain"
is_object_unsuspended 'web' 'DOMAIN' "$domain"

if [ -z "$app_root" ] || [ "$app_root" = "json" ] || [ "$app_root" = "plain" ] || [ "$app_root" = "csv" ] || [ "$app_root" = "shell" ]; then
	format=${app_root:-$format}
	app_root="$(laravel_default_app_root)"
fi

app_root="$(laravel_validate_app_root "$app_root")"
if ! laravel_is_app_root "$app_root"; then
	check_result "$E_NOTEXIST" "Laravel application files not found in $app_root"
fi

web_record="$(grep "DOMAIN='$domain'" "$USER_DATA/web.conf")"
parse_object_kv_list "$web_record"
if [[ "$BACKEND" =~ ^PHP-([0-9])_([0-9])$ ]]; then
	php_version="${BASH_REMATCH[1]}.${BASH_REMATCH[2]}"
else
	php_version="$(php -r 'echo substr(PHP_VERSION, 0, 3);' 2> /dev/null || echo '8.3')"
fi

laravel_add_app_record "$domain" "$app_root" "$php_version" "local" "" ""

$BIN/v-change-web-domain-tpl "$user" "$domain" laravel no
check_result $? "Failed to change web template to laravel"

$BIN/v-rebuild-web-domain "$user" "$domain" yes
check_result $? "Failed to rebuild web domain"

$BIN/v-list-laravel-app "$user" "$domain" "$format"

log_event "$OK" "$ARGUMENTS"
exit
