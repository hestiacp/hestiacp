#!/bin/bash
# info: disables support for single sign on phpPgAdmin
# options: [mode]
#
# example: v-delete-sys-pga-sso
#
# Disables support for SSO to phpPgAdmin

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

MODE=$1

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source /etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

PGA_INSTALL="/usr/share/phppgadmin"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

if [ "x$(id -u)" != 'x0' ]; then
	echo "Error: Script can be run executed only by root"
	exit 10
fi

if [ ! -e "$PGA_INSTALL/hestia-sso.php" ]; then
	echo 'Error: PGA Single Sign On already disabled'
	exit 1
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

apikey=$(grep -Po 'define\("API_KEY", "\K[^"]+' $PGA_INSTALL/hestia-sso.php | cut -d: -f1)

if [ -n "$apikey" ]; then
	$BIN/v-delete-access-key "$apikey"
fi

# remove SSO file
rm $PGA_INSTALL/hestia-sso.php

# disable key
$BIN/v-change-sys-config-value 'PHPPGADMIN_KEY' ""

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

if [ "$MODE" != "quiet" ]; then
	echo "PGA Hestia-SSO plugin has been successfully removed/disabled"
fi

# Logging
$BIN/v-log-action "system" "Info" "Plugins" "phpPgAdmin Single Sign-On (SSO) disabled."
log_event "$OK" "$ARGUMENTS"

exit
